# =============================================================================
# Amelia — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local and fill in your values.
# IMPORTANT: Variables marked [Convex] must be set via:
#   npx convex env set KEY "value"
# Convex actions run server-side and cannot read .env.local directly.
# =============================================================================

# -----------------------------------------------------------------------------
# CONVEX
# From: dashboard.convex.dev → your project → Settings → URL & Deploy Key
# -----------------------------------------------------------------------------
CONVEX_DEPLOYMENT=dev:your-project-slug
VITE_CONVEX_URL=https://your-slug.convex.cloud
VITE_CONVEX_SITE_URL=https://your-slug.convex.site

# -----------------------------------------------------------------------------
# CLERK — Authentication
# From: clerk.com → Dashboard → your app → API Keys
# VITE_ vars go in .env.local; secret key and webhook secret go in Convex [Convex]
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx            # [Convex]
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx  # [Convex]

# Clerk redirect URLs
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
VITE_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding

# -----------------------------------------------------------------------------
# INTERSWITCH — Quickteller Business (Card Payments)
# From: business.quickteller.com → Settings
# Auth: SHA-512 hash signing — NOT OAuth. All values go in Convex [Convex]
# Sandbox endpoints use qa.interswitchng.com
# -----------------------------------------------------------------------------
INTERSWITCH_CLIENT_ID=IKIA_xxxxxxxxxxxxxxxx              # [Convex]
INTERSWITCH_SECRET_KEY=your_secret_key                   # [Convex]
INTERSWITCH_MERCHANT_CODE=MXxxxxxx                       # [Convex]
INTERSWITCH_PAY_ITEM_ID=Default_Payable_MXxxxxxx         # [Convex]
INTERSWITCH_MAC_KEY=your_mac_key                         # [Convex]
INTERSWITCH_WEBHOOK_SECRET=your_webhook_secret           # [Convex]

# -----------------------------------------------------------------------------
# INTERSWITCH — Developer Marketplace (Identity Verification)
# From: developer.interswitchgroup.com → your project → Credentials
# OAuth 2.0 client_credentials flow. APIs: VerifyMeNin, UVBankVerification
# -----------------------------------------------------------------------------
ISW_MARKETPLACE_CLIENT_ID=IKIA_xxxxxxxxxxxxxxxx          # [Convex]
ISW_MARKETPLACE_CLIENT_SECRET=your_marketplace_secret   # [Convex]
ISW_MARKETPLACE_BASE_URL=https://qa.interswitchng.com   # [Convex]

# -----------------------------------------------------------------------------
# MISTRAL AI — OCR
# From: console.mistral.ai → API Keys
# Model: mistral-ocr-latest (document extraction) + mistral-small-latest (JSON parse)
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=your_mistral_api_key                     # [Convex]

# -----------------------------------------------------------------------------
# INNGEST — Durable Background Jobs
# From: inngest.com → Dashboard → your app → Manage → Keys
# INNGEST_DEV=1 enables local dev mode (serve-mode with inngest-cli)
# -----------------------------------------------------------------------------
INNGEST_DEV=1
INNGEST_EVENT_KEY=your_inngest_event_key                 # [Convex]
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxxxxxx    # [Convex]

# -----------------------------------------------------------------------------
# META WHATSAPP CLOUD API — Payment Request Notifications
# From: developers.facebook.com → your app → WhatsApp → API Setup
# Template used: bill_payment_request (must be approved in WhatsApp Manager)
# -----------------------------------------------------------------------------
META_ACCESS_TOKEN=your_meta_system_user_or_permanent_token  # [Convex]
META_APP_ID=your_meta_app_id                                # [Convex]
META_APP_SECRET=your_meta_app_secret                        # [Convex]
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id          # [Convex]
META_SENDER_NUMBER=+234xxxxxxxxxx                           # [Convex]
META_WABA_ID=your_whatsapp_business_account_id              # [Convex]
META_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token          # [Convex]
META_GRAPH_API_VERSION=v23.0                                # [Convex]

# -----------------------------------------------------------------------------
# RESEND — Transactional Email
# From: resend.com → API Keys
# Used for: welcome email on new clinic signup (Clerk → Inngest → Resend)
# Verify your sending domain in Resend before using a custom from address
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx                   # [Convex]
RESEND_FROM_EMAIL=onboarding@your-domain.com            # [Convex]

# -----------------------------------------------------------------------------
# GROQ — LLM Claim Completeness Scoring
# From: console.groq.com → API Keys
# Model: moonshotai/kimi-k2-instruct-0905
# Used to score claims green/amber/red before PDF generation
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx                    # [Convex]
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905             # [Convex]
GROQ_BASE_URL=https://api.groq.com/openai/v1            # [Convex]
GROQ_TEMPERATURE=0.6                                     # [Convex]
GROQ_MAX_COMPLETION_TOKENS=4096                          # [Convex]
GROQ_TOP_P=1                                             # [Convex]

# -----------------------------------------------------------------------------
# E2B — Sandboxed Code Execution (optional)
# From: e2b.dev → Dashboard → API Keys
# Used for isolated PDF generation jobs (not active in current phase)
# -----------------------------------------------------------------------------
E2B_API_KEY=e2b_xxxxxxxxxxxxxxxxxxxx                     # [Convex]

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5173
# Production: VITE_APP_URL=https://app.getamelia.online
